{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (use local VkP2 submodule)",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FETCHCONTENT_SOURCE_DIR_VKP2": "${sourceDir}/vendor/VkP2"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (use local VkP2 submodule)",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FETCHCONTENT_SOURCE_DIR_VKP2": "${sourceDir}/vendor/VkP2"
            }
        },
        {
            "name": "release",
            "displayName": "Release (use local VkP2 submodule)",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FETCHCONTENT_SOURCE_DIR_VKP2": "${sourceDir}/vendor/VkP2"
            }
        },
        {
            "name": "fetch-vkp2",
            "displayName": "Release (fetch VkP2 from GitHub)",
            "binaryDir": "${sourceDir}/build-fetch",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        { "name": "default", "configurePreset": "default" },
        { "name": "debug", "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" },
        { "name": "fetch-vkp2", "configurePreset": "fetch-vkp2" }
    ]
}
